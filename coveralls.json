{
  "coverage_options": {
    "minimum_coverage": 99,
    "treat_no_relevant_lines_as_covered": true,
    "output_dir": "cover/",
    "html_filter_full_covered": false,
    "floor_coverage": true
  },
  "terminal_options": {
    "file_column_width": 50,
    "print_files": true
  },
  "skip_files": [
    "test/",
    "lib/vaultx/test/"
  ],
  "default_stop_words": [
    "defmodule",
    "defstruct",
    "defexception",
    "def.+(.+\\/\\/.+).+do",
    "@doc",
    "@moduledoc",
    "@spec",
    "@type"
  ],
  "custom_stop_words": [
    "require Logger",
    "use GenServer",
    "use Application"
  ]
}